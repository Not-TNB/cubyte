; reg 0 alg="D L2 U' B2 U R2 F2 B2 U F2 L' B2 R' D2 L' R2 D2 R'" order=18
; reg 1 alg="F2 U2 R2 B2 L2 D' L2 B2 R2 U F2" order=3
1  start:
2  D L2 U' B2 U R2 F2 B2 U F2 L' B2 R' D2 L' R2 D2 R'
3  branch cycle(UF,DF,FL,FR,BL) __cond_true_0
4  goto __cond_false_1
5  __cond_true_0:
6  goto done
7  goto __cond_end_2
8  __cond_false_1:
9  __cond_end_2:
10  goto start
11  done:
12  output (R D2 L R2 D2 R B2 L F2 U' F2 B2 R2 U' B2 U L2 D') (UFL,UFR,UBL,UBR,DFL,DFR,DBL,DBR)
